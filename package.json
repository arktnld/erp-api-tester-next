{
  "name": "erp-api-tester",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter web dev\" \"pnpm --filter api dev\"",
    "build": "pnpm --filter db build && pnpm --filter web build",
    "db:generate": "pnpm --filter db generate",
    "db:migrate": "pnpm --filter db migrate"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "protobufjs"
    ]
  }
}