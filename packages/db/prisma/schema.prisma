generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ERP {
  id           Int              @id @default(autoincrement())
  name         String           @unique
  createdAt    DateTime         @default(now())
  companies    Company[]
  endpoints    Endpoint[]
  fieldSchemas ERPFieldSchema[]
}

model ERPFieldSchema {
  id               Int     @id @default(autoincrement())
  erpId            Int
  fieldName        String
  label            String
  fieldType        String  @default("text")
  required         Boolean @default(false)
  sortOrder        Int     @default(0)
  sourceEndpointId Int?
  endpointParam    String  @default("")
  responsePath     String  @default("")
  erp              ERP     @relation(fields: [erpId], references: [id], onDelete: Cascade)
}

model Endpoint {
  id             Int     @id @default(autoincrement())
  erpId          Int
  name           String
  method         String  @default("GET")
  pathTemplate   String
  bodyTemplate   String  @default("")
  headers        String  @default("{}")
  sortOrder      Int     @default(0)
  group          String  @default("")
  requiresClient  Boolean @default(true)
  isModification  Boolean @default(false)
  erp             ERP     @relation(fields: [erpId], references: [id], onDelete: Cascade)
}

model Company {
  id          Int          @id @default(autoincrement())
  name        String
  erpId       Int
  baseUrl      String       @default("")
  environments String       @default("[]")
  authType     String       @default("none")
  authConfig   String       @default("{}")
  createdAt   DateTime     @default(now())
  erp         ERP          @relation(fields: [erpId], references: [id])
  testClients TestClient[]
}

model TestClient {
  id         Int      @id @default(autoincrement())
  name       String
  companyId  Int
  fieldsData String   @default("{}")
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model PostmanCollection {
  id           Int              @id @default(autoincrement())
  name         String
  context      String           @db.Text
  systemPrompt String           @default("")
  createdAt    DateTime         @default(now())
  chunks       EmbeddingChunk[]
}

model EmbeddingChunk {
  id           Int               @id @default(autoincrement())
  collectionId Int
  text         String            @db.Text
  embedding    Unsupported("vector(1536)")
  collection   PostmanCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model Setting {
  key   String @id
  value String @db.Text
}

model RequestHistory {
  id              Int      @id @default(autoincrement())
  erpName         String
  companyName     String
  endpointName    String
  clientName      String
  method          String
  url             String
  requestBody     String   @default("") @db.Text
  requestHeaders  String   @default("{}")
  statusCode      Int
  responseBody    String   @default("") @db.Text
  responseHeaders String   @default("{}")
  durationMs      Int
  companyId       Int?
  endpointId      Int?
  testClientId    Int?
  createdAt       DateTime @default(now())
}
